{
  "name": "cozy-corkboard",
  "version": "1.0.1",
  "private": true,
  "author": "cosyh",
  "description": "a cozy pixel-art corkboard task manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "cross-env NODE_ENV=production vite build && electron-packager . \"cozy corkboard\" --platform=win32 --arch=x64 --out=release --overwrite --executableName=\"click to run\" --ignore=\"release|src|.git\"",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "publish": "powershell -ExecutionPolicy Bypass -File scripts/publish-github.ps1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.4.0",
    "wait-on": "^8.0.3"
  }
}
